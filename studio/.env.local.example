# ─── Authentication ─────────────────────────────────────────
# The single admin account that can log in
ADMIN_EMAIL=you@yourdomain.com
# Generate a bcrypt hash: node -e "const b=require('bcryptjs');console.log(b.hashSync('YourPassword',12))"
ADMIN_PASSWORD_HASH=$2b$12$...

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── BytePlus ModelArk ────────────────────────────────────────
# Get from: https://console.byteplus.com/ark/apiKey
BYTEPLUS_API_KEY=your-api-key-here

# Region endpoint — ap-southeast-1 for Southeast Asia accounts
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# ─── Contact form (Resend) ───────────────────────────────────
RESEND_API_KEY=re_...
CONTACT_FROM_EMAIL="Xethra <you@yourdomain.com>"
CONTACT_TO_EMAIL=you@yourdomain.com

# ─── Agent API (optional) ─────────────────────────────────────
XETHRA_AGENT_KEY=generate-a-random-secret

# ─── Gemini (Nano Banana Pro images + content agent planner) ─
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional overrides:
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# ─── Vercel Blob (auto-set on Vercel when Blob store is linked) ─
# BLOB_READ_WRITE_TOKEN=
